# ScanR Environment Configuration
# Copy to .env and fill in all required values before starting

# ── Security (REQUIRED) ───────────────────────────────────────────────────────

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Fernet key for credential vault — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=

# ── Database (REQUIRED) ───────────────────────────────────────────────────────

# Password for the PostgreSQL scanr user
POSTGRES_PASSWORD=

# ── Admin Bootstrap (REQUIRED) ───────────────────────────────────────────────

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API
# Default is http://localhost (suitable for local Docker deployment)
# For HTTP access over a private LAN/Tailscale IP, add that origin here and set
# SECURE_COOKIES=false in your local .env. Keep SECURE_COOKIES=true for HTTPS.
# Example: ALLOWED_ORIGINS=http://localhost,http://100.x.y.z
ALLOWED_ORIGINS=http://localhost
SECURE_COOKIES=true

# ── Scan Defaults ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_HOSTS=50
MAX_CONCURRENT_PLUGINS=20
DEFAULT_SCAN_TIMEOUT=3600

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false

# Docker image tag used by docker compose pull/up. Use "latest" for simple
# updates, or pin a version such as "0.9.1" for controlled deployments.
SCANR_VERSION=latest

# ── Optional In-App Updates ──────────────────────────────────────────────────
# Disabled by default. Enabling this gives the API container access to the host
# Docker socket through docker-compose.self-update.yml, so only enable it for
# trusted admin-only deployments.
SELF_UPDATE_ENABLED=false
SELF_UPDATE_COMMAND=docker-compose -f docker-compose.yml -f docker-compose.self-update.yml pull && docker-compose -f docker-compose.yml -f docker-compose.self-update.yml up -d
SCANR_PROJECT_DIR=.
DOCKER_SOCKET=/var/run/docker.sock
