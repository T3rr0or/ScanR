# ScanR Environment Configuration
# Copy to .env and fill in all required values before starting

# ── Security (REQUIRED) ───────────────────────────────────────────────────────

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Fernet key for credential vault — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=

# ── Database (REQUIRED) ───────────────────────────────────────────────────────

# Password for the PostgreSQL scanr user
POSTGRES_PASSWORD=

# ── Admin Bootstrap (REQUIRED) ───────────────────────────────────────────────

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API
# Default is http://localhost (suitable for local Docker deployment)
# For HTTP access over a private LAN/Tailscale IP, add that origin here and set
# SECURE_COOKIES=false in your local .env. Keep SECURE_COOKIES=true for HTTPS.
# Example: ALLOWED_ORIGINS=http://localhost,http://100.x.y.z
ALLOWED_ORIGINS=http://localhost
SECURE_COOKIES=true

# Trusted reverse-proxy peers (comma-separated IPs/CIDRs). X-Forwarded-For is
# only honoured for rate limiting when the direct peer is in this list, so
# clients can't spoof their source IP. Leave empty if the API is exposed
# directly (no proxy). Example: TRUSTED_PROXIES=172.16.0.0/12
TRUSTED_PROXIES=

# ── Scan Defaults ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_HOSTS=50
MAX_CONCURRENT_PLUGINS=20
DEFAULT_SCAN_TIMEOUT=3600

# Hostnames/IPs that may never be a scan target (the scanner's own
# infrastructure). Merged with a built-in denylist that always rejects
# loopback, link-local (incl. 169.254.169.254 cloud metadata), multicast,
# reserved, and unspecified addresses.
SCAN_TARGET_DENYLIST=localhost,postgres,redis,db,scanr-api,scanr-worker

# Mark scans whose worker heartbeat goes stale (worker crash/OOM) as failed
# after this many seconds, instead of leaving them stuck in "running".
SCAN_HEARTBEAT_TIMEOUT=300

# ── AI features (optional) ────────────────────────────────────────────────────
# Powers AI-assisted findings summaries (and, later, report narrative,
# false-positive testing, and autonomous pentest modes). Requires the AI extra:
#   pip install -e "backend[ai]"   (or build the image with it)
# Provider ∈ anthropic | openai | deepseek. Leave AI_MODEL blank to use the
# provider's default. Set the key only for the provider(s) you use — keys are
# never logged or sent to the model as content.
AI_PROVIDER=anthropic
AI_MODEL=
AI_MAX_TOKENS=2048
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── AI command-execution sandbox (optional, advanced) ─────────────────────────
# Gives the AI agent a real shell in a dedicated, network-scoped, disposable
# container (see docs/ai-sandbox-design.md). Empty SANDBOX_RUNNER_URL = command
# execution disabled (fail-closed). Requires the separate sandbox-runner service.
SANDBOX_RUNNER_URL=
SANDBOX_TOKEN=
SANDBOX_IMAGE=scanr-sandbox:latest
SANDBOX_CMD_TIMEOUT=120

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false

# Docker image tag used by docker compose pull/up. Use "latest" for simple
# updates, or pin a version such as "0.9.1" for controlled deployments.
SCANR_VERSION=latest

# ── Optional In-App Updates ──────────────────────────────────────────────────
# Set SELF_UPDATE_ENABLED=true to unlock the "Update Now" button in
# Settings > System. Requires Docker socket access on the host.
# Start with docker-compose.self-update.yml so the Docker socket and project
# directory are mounted only for trusted admin-only deployments:
# docker compose -f docker-compose.yml -f docker-compose.self-update.yml up -d
SELF_UPDATE_ENABLED=false
