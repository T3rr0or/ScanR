# ScanR Environment Configuration
# Copy this to .env and fill in values

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=ScanR
DEBUG=false

# ── Security (CHANGE IN PRODUCTION) ──────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_python3_-c_"import_secrets;print(secrets.token_urlsafe(32))"

# Fernet key for credential vault — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=CHANGE_ME_fernet_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./scanr.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://scanr:password@localhost/scanr

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@scanr.local
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Scan Defaults ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_HOSTS=50
MAX_CONCURRENT_PLUGINS=20
DEFAULT_SCAN_TIMEOUT=3600

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=./reports

# ── NVD CVE Feeds ─────────────────────────────────────────────────────────────
NVD_CACHE_DIR=./nvd_cache
